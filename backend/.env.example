# ── NVIDIA / Riva credentials ──────────────────────────────────────────────
# Get your key at: https://build.nvidia.com/nvidia/riva-translate-1_6b
NVIDIA_API_KEY=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

# ── Riva gRPC endpoint (do not change unless NVIDIA updates it) ────────────
RIVA_SERVER=grpc.nvcf.nvidia.com:443

# ── NIM function ID (do not change unless NVIDIA updates it) ──────────────
RIVA_FUNCTION_ID=0778f2eb-b64d-45e7-acae-7dd9b9b35b4d

# ── Optional: force a specific model name (leave blank = auto-resolve) ─────
RIVA_MODEL=

# ── Server port ────────────────────────────────────────────────────────────
PORT=3001

# ── Allowed frontend origin for CORS (used in production on Render) ────────
# Example: https://rivatranslate-frontend.onrender.com
FRONTEND_URL=https://rivatranslate.onrender.com